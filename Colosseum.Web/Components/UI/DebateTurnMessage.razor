@namespace Colosseum.Web.Components.UI
@using Colosseum.Core.Models

<div class="msg @(HasMentions ? "rebuttal" : "") @(_isCont ? "cont" : "")" style="--g-col:@Turn.GladiatorAccentColour">
  <div class="msg-avatar">@Turn.GladiatorName[0]</div>
  <div class="msg-body">
    @if (!_isCont)
    {
      <div class="msg-meta">
        <span class="msg-name">@Turn.GladiatorName</span>
        <span class="msg-domain">@Turn.GladiatorDomain</span>
        <span class="msg-time">@Turn.Timestamp.ToLocalTime().ToString("H:mm")</span>
      </div>
    }
    <div class="msg-text">@((MarkupString)RenderText())</div>

    @foreach (var issueId in Turn.ReferencedIssueIds)
    {
      var issue = AllIssues.FirstOrDefault(i => i.Id == issueId);
      if (issue is not null)
      {
        <div class="msg-overlap-flag" @onclick="() => OnIssueClick.InvokeAsync(issue.Id)">
          <span class="overlap-icon">⚭</span>
          May overlap: <strong>@issue.Title</strong>
          <span class="flag-arr" style="margin-left:auto">→</span>
        </div>
      }
    }
  </div>
</div>

@code {
  [Parameter, EditorRequired] public DebateTurn Turn { get; set; } = null!;
  [Parameter] public IReadOnlyList<Issue> AllIssues { get; set; } = [];
  [Parameter] public EventCallback<Guid> OnIssueClick { get; set; }

  // Passed explicitly by the parent loop — no CascadingParameter needed.
  [Parameter] public string? PreviousGladiator { get; set; }

  bool _isCont => PreviousGladiator == Turn.GladiatorName;
  bool HasMentions => Turn.Mentions.Count > 0;

  string RenderText()
  {
    var text = System.Net.WebUtility.HtmlEncode(Turn.Text);

    // Replace @Name mentions with coloured chips.
    // All match group values are HTML-encoded before injection.
    text = System.Text.RegularExpressions.Regex.Replace(
      text,
      @"@([A-Za-z]+)",
      m =>
      {
        var name = System.Net.WebUtility.HtmlEncode(m.Groups[1].Value);
        var colour = name.ToLowerInvariant() switch
        {
          "maximus" => "var(--maximus)",
          "brutus"  => "var(--brutus)",
          "cassius" => "var(--cassius)",
          "valeria" => "var(--valeria)",
          "arbiter" => "var(--arbiter)",
          _ => "var(--gold)"
        };
        return $"""<span class="mention" style="--m-col:{colour}">@{name}</span>""";
      });

    // Highlight [ISSUE: ...] tags — encode captured groups before embedding.
    text = System.Text.RegularExpressions.Regex.Replace(
      text,
      @"\[ISSUE:\s*([^\|]+)\|\s*severity:\s*(\w+)\s*\]",
      m =>
      {
        var title = System.Net.WebUtility.HtmlEncode(m.Groups[1].Value.Trim());
        var severity = System.Net.WebUtility.HtmlEncode(m.Groups[2].Value);
        return $"""<span class="inline-issue-tag">[ISSUE: {title} | {severity}]</span>""";
      },
      System.Text.RegularExpressions.RegexOptions.IgnoreCase);

    return text;
  }
}

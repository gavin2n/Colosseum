@namespace Colosseum.Web.Components.UI
@using Colosseum.Core.Models
@inject IJSRuntime JS

<div class="issue-card @(Issue.Status == IssueStatus.Dismissed ? "dismissed" : "") @(Issue.MergeCandidate.HasValue ? "merge-candidate" : "") @(_open ? "open" : "")"
     id="issue-@Issue.Id" style="--i-col:@GladiatorColour(Issue.RaisedByGladiatorName)">

  <div class="issue-head" @onclick="Toggle">
    <div class="issue-top">
      <span class="issue-rank @(Issue.Status == IssueStatus.Dismissed ? "dismissed-rank" : "")">
        @(Issue.Status == IssueStatus.Dismissed ? "✕" : $"#{Rank}")
      </span>
      <span class="issue-title">@Issue.Title</span>
      <span class="issue-chevron">▶</span>
    </div>
    <div class="issue-badges">
      <span class="badge badge-@Issue.Severity.ToString().ToLower()">@Issue.Severity</span>
      <span class="badge badge-dom">@Issue.RaisedByGladiatorName</span>
      @if (Issue.MergeCandidate.HasValue)
      {
        <span class="merge-badge" @onclick:stopPropagation @onclick="() => ScrollToIssue(Issue.MergeCandidate!.Value)">
          <span class="merge-badge-icon">⚭</span> may overlap
        </span>
      }
    </div>
    <div class="vote-row">
      <span class="vote-for">▲ @Issue.VotesFor</span>
      <div class="vote-bar">
        <div class="vote-fill" style="width:@VotePct%"></div>
      </div>
      <span class="vote-against">▼ @Issue.VotesAgainst</span>
    </div>
  </div>

  <div class="issue-detail">
    <div class="issue-detail-inner">
      @if (Issue.MergeCandidate.HasValue)
      {
        var other = AllIssues.FirstOrDefault(i => i.Id == Issue.MergeCandidate);
        <div class="detail-merge-notice">
          <div class="detail-merge-icon">⚭</div>
          <div class="detail-merge-text">
            <strong>Flagged as merge candidate</strong>
            @if (other is not null)
            {
              <span> with "@other.Title".</span>
              <span class="detail-merge-link" @onclick="() => ScrollToIssue(other.Id)">View counterpart →</span>
            }
            <span> Arbiter will rule: Merge, Distinguish, or Dismiss.</span>
          </div>
        </div>
      }

      <div class="detail-section-label">Debate Trail</div>
      @foreach (var entry in Issue.DebateTrail)
      {
        <div class="detail-msg" style="--g-col:@GladiatorColour(entry.GladiatorName)">
          <div class="detail-avatar">@(entry.GladiatorName.Length > 0 ? entry.GladiatorName[0] : '?')</div>
          <div class="detail-body">
            <div class="detail-name">
              @entry.GladiatorName
              <span class="detail-stance stance-@entry.Stance.ToString().ToLower()">@entry.Stance.ToString().ToLower()</span>
            </div>
            <div class="detail-text">@entry.Text</div>
          </div>
        </div>
      }
    </div>
  </div>
</div>

@code {
  [Parameter, EditorRequired] public Issue Issue { get; set; } = null!;
  [Parameter] public IReadOnlyList<Issue> AllIssues { get; set; } = [];
  /// <summary>Pre-computed rank passed from parent to avoid O(n²) per-render sort.</summary>
  [Parameter] public int Rank { get; set; }

  bool _open;

  double VotePct
  {
    get
    {
      var total = Issue.VotesFor + Issue.VotesAgainst;
      return total == 0 ? 0 : (double)Issue.VotesFor / total * 100;
    }
  }

  void Toggle() => _open = !_open;

  async Task ScrollToIssue(Guid id)
    => await JS.InvokeVoidAsync("scrollToIssue", $"issue-{id}");

  static string GladiatorColour(string name) => name.ToLower() switch
  {
    "maximus" => "var(--maximus)",
    "brutus"  => "var(--brutus)",
    "cassius" => "var(--cassius)",
    "valeria" => "var(--valeria)",
    "arbiter" => "var(--arbiter)",
    _ => "var(--gold)"
  };
}

{
  "version": "0.2.0",
  "configurations": [

    // ── Colosseum.Web ────────────────────────────────────────────────────────

    {
      "name": "Debug: Web (http)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/Colosseum.Web/bin/Debug/net10.0/Colosseum.Web",
      "args": [],
      "cwd": "${workspaceFolder}/Colosseum.Web",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5287"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Colosseum.Web/Components"
      }
    },

    {
      "name": "Debug: Web (https)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/Colosseum.Web/bin/Debug/net10.0/Colosseum.Web",
      "args": [],
      "cwd": "${workspaceFolder}/Colosseum.Web",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7273;http://localhost:5287"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Colosseum.Web/Components"
      }
    },

    {
      "name": "Debug: Web (SDK provider)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/Colosseum.Web/bin/Debug/net10.0/Colosseum.Web",
      "args": [],
      "cwd": "${workspaceFolder}/Colosseum.Web",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5287",
        // Switch to the Anthropic SDK backend — set your key in the env or user secrets
        "Colosseum__Provider": "Sdk",
        "Colosseum__AnthropicApiKey": "${env:ANTHROPIC_API_KEY}"
      }
    },

    // ── Tests ────────────────────────────────────────────────────────────────

    {
      "name": "Debug: Unit Tests",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/Colosseum.Tests/",
        "--logger",
        "console;verbosity=detailed"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },

    // ── Attach ───────────────────────────────────────────────────────────────

    {
      "name": "Attach: running process",
      "type": "coreclr",
      "request": "attach",
      "processName": "Colosseum.Web"
    }
  ],

  "compounds": [
    {
      "name": "Web + Tests",
      "configurations": ["Debug: Web (http)", "Debug: Unit Tests"],
      "stopAll": true
    }
  ]
}
